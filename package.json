{
  "name": "vibe-telegram-bot",
  "version": "0.1.0",
  "description": "Telegram bot client for Mistral Vibe via ACP protocol",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "grammy": "^1.39.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
