# Telegram Bot Token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram User ID (required) - get it from @userinfobot
TELEGRAM_ALLOWED_USER_ID=

# Default working directory for Vibe sessions (required)
VIBE_PROJECT_DIR=/path/to/your/project

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
